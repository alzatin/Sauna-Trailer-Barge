                            },
                            {
                              "atomType": "Code",
                              "x": 0.4901746724890829,
                              "y": 0.7515151515151516,
                              "uniqueID": "id-226040",
                              "ioValues": [
                                {
                                  "name": "Number",
                                  "ioValue": 6
                                },
                                {
                                  "name": "distX",
                                  "ioValue": 0
                                },
